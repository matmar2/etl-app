{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": false }
    },
    "adhoc": {
      "distribution": "internal",
      "channel": "adhoc",
      "autoIncrement": true,
      "ios": { "resourceClass": "m-medium" }
    },
    "f2stestflight": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "ios": { "resourceClass": "m-medium" }
    }
  },
  "submit": {
    "f2stestflight": {
      "ios": {
        "appleId": "mathewos.gobena@fly2sky.aero",
        "ascAppId": "6787216007",
        "appleTeamId": "B3F45CXANN"
      }
    }
  }
}
